{
  "schemaVersion": 1,
  "id": "hudifine",
  "version": "${version}",
  "name": "Hudifine",
  "description": "Scriptable HUD GUI library with in-chat editor, drag mode, and per-widget customization.",
  "authors": [
    "Hudifine"
  ],
  "contact": {
    "homepage": "https://example.invalid/hudifine"
  },
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "main": [
      "com.hudifine.HudifineMod"
    ],
    "client": [
      "com.hudifine.client.HudifineClientMod"
    ]
  },
  "mixins": [
    "hudifine.client.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.6",
    "minecraft": "26.1.2",
    "java": ">=21",
    "fabric-api": "*"
  }
}
